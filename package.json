{
  "name": "dine-in-order",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "server",
    "shared",
    "admin",
    "staff",
    "customer"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:admin\" \"npm run dev:staff\" \"npm run dev:customer\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:admin": "npm run dev --workspace=admin",
    "dev:staff": "npm run dev --workspace=staff",
    "dev:customer": "npm run dev --workspace=customer",
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
